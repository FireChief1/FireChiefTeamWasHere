# Copy this file to .env and adjust values for your environment.
# .env is git-ignored and must never be committed.

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
# Context window passed to Ollama. Raise if project-mode prompts get truncated;
# higher values use more VRAM for the KV cache.
LLM_NUM_CTX=8192
# Max tokens generated per call. Bounds runaway output; raise for large
# multi-file generation, or set to -1 to disable the cap.
LLM_NUM_PREDICT=4096
# Fixed RNG seed for reproducible generation (matters most for the temp-0
# router and low-temp reviewer). Set to -1 to let Ollama randomize.
LLM_SEED=0

# --- Models ---
CHAT_MODEL=qwen2.5:14b
CODER_MODEL=qwen2.5-coder:14b
REASONER_MODEL=qwen2.5-coder:14b
# Keep FALLBACK on a different tag than CODER so it forms an independent node;
# otherwise an open coder circuit leaves no usable fallback.
FALLBACK_MODEL=qwen2.5:14b
VISION_MODEL=qwen2.5vl:7b
EMBEDDING_MODEL=nomic-embed-text

# --- Project exploration (optional, bounded model-driven file discovery) ---
# OFF by default. When true, Project Intake lets the model request a few extra
# files to read/search before the workflow runs. Bounded to stay cheap locally.
PROJECT_EXPLORE_ENABLED=false
PROJECT_EXPLORE_MAX_STEPS=6
PROJECT_EXPLORE_MAX_BYTES=40000

# --- Git remote (for the human-gated push; leave blank to disable push) ---
GIT_REMOTE=
GIT_TOKEN=

# --- Database (Postgres, run via docker-compose) ---
POSTGRES_DB=codeteam
POSTGRES_USER=codeteam
POSTGRES_PASSWORD=codeteam
POSTGRES_PORT=5434
DATABASE_URL=postgresql://codeteam:codeteam@localhost:5434/codeteam

# --- Optional: LangSmith tracing ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
